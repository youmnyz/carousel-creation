# Copy this file to .env and fill in your values

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Your WordPress site URL (no trailing slash)
WP_SITE_URL=https://yourblog.com

# Where to save the generated .pptx carousel files
OUTPUT_FOLDER=C:/Users/yourname/Documents/Carousels

# Brand colors for carousel slides (hex codes)
BRAND_COLOR=#4A90D9
ACCENT_COLOR=#FFFFFF

# Path to your 5-slide PowerPoint template (default: template.pptx in this folder)
# TEMPLATE_FILE=C:/path/to/your/template.pptx
